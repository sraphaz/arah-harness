{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event session-start",
        "timeout": 20
      }
    ],
    "sessionEnd": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event session-end",
        "timeout": 15
      }
    ],
    "subagentStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event subagent-start",
        "timeout": 15
      }
    ],
    "subagentStop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event subagent-stop",
        "timeout": 15
      }
    ],
    "postToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event tool-use",
        "matcher": "Task",
        "timeout": 15
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event agent-edit",
        "matcher": "Write|StrReplace|EditNotebook|Delete",
        "timeout": 20
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event file-edit",
        "timeout": 20
      }
    ],
    "stop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event turn-stop",
        "timeout": 15,
        "loop_limit": 1
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/domain-review.ps1",
        "timeout": 90,
        "loop_limit": 1
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event conversation-focus -PromptHook",
        "matcher": "UserPromptSubmit",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/live-session.ps1 -Event conversation-focus",
        "timeout": 8
      }
    ]
  }
}
